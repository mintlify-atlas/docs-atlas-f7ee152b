  "keyFeatures": [
    "Pre-execution policy enforcement with PERMIT/DENY/DEFER",
    "Policy-as-code using YAML and expr-lang expressions",
    "Tamper-evident DPR (Decision-Provenance Record) chain",
    "Human-in-the-loop DEFER workflow for sensitive actions",
    "Multi-agent governance and cross-agent coordination",
    "Six deployment adapters (SDK, daemon, sidecar, serverless, MCP, eBPF)",
    "Session state tracking and history-based rules",
    "Pre/post-condition scanners for shell, secrets, and PII",
    "WAL-first ordering invariant for audit integrity",
    "Cloud platform integration for advanced features"
  ],
  "publicApiSurface": [
    "faramesh demo - Interactive demo of governance in action",
    "faramesh serve - Start the governance daemon",
    "faramesh init - Auto-detect environment and generate config",
    "faramesh policy validate - Validate policy files",
    "faramesh policy inspect - Inspect compiled policy",
    "faramesh audit tail - Stream live governance decisions",
    "faramesh audit verify - Verify DPR chain integrity",
    "faramesh agent approve - Approve pending DEFER",
    "faramesh agent deny - Deny pending DEFER",
    "faramesh agent kill - Activate agent kill switch",
    "govern() - Python decorator for governed functions",
    "Policy YAML schema - faramesh-version, rules, vars, tools",
    "CanonicalActionRequest - Core governance request type",
    "Decision - PERMIT/DENY/DEFER/SHADOW response",
    "DPR Chain - Tamper-evident audit record chain",
    "Session State API - Track agent behavior across calls",
    "MCP Gateway - Faramesh as MCP server"
  ]
}
